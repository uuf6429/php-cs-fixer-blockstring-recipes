{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "cases",
        "require"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": "",
        "name": {
            "type": "string",
            "nullable": false
        },
        "cases": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                    "type": "string",
                    "pattern": "^cases(/[^/]+)+$",
                    "nullable": false
                },
                "nullable": false
            },
            "nullable": false
        },
        "require": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
                "^(php|docker|windows|(bin|ext|wsl|docker)-.+)$": {
                    "type": "string",
                    "pattern": "^\\*|[0-9]+(\\.[0-9]+)*$",
                    "nullable": false
                }
            },
            "nullable": false
        }
    }
}
